<QUERY3>
WITH LASTxHOLEREPORT AS (
  SELECT * 
  FROM inventinv@heinens_custom_prod 
  WHERE eintinv = 22 /* Not PICS/RGIS */
  AND einsite=:param2
  AND TRUNC(eindinv) >=TRUNC(SYSDATE-:param3)
  ORDER BY eindinv DESC
),
IDENTIFY_ITEMS AS(
  SELECT COUNT(DISTINCT(dincinl)) cnt, MAX(TRUNC(eindinv)) maxDinv, dincinl, einsite, dincinr
  FROM invdetinv@heinens_custom_prod, LASTxHOLEREPORT
  WHERE dincininv=eincininv
  AND dinsite=einsite
  HAVING COUNT(1) >= :param3
  GROUP BY dincinl, einsite, dincode, dincinr),
 IDENTIFY_ITEMS_FILTERED AS(
  SELECT cnt,  maxDinv, dincinl, einsite, dincinr,
         pkresrel.isSiteBelongToNode@heinens_custom_prod(1,:param2, 1101, ''1'') "CLE",
         pkresrel.isSiteBelongToNode@heinens_custom_prod(1,:param2, 1102, ''1'') "CHI"
  FROM IDENTIFY_ITEMS
  WHERE maxDinv=TRUNC(SYSDATE)
),
distinct_dates AS (
  SELECT DISTINCT det.dincinl item_code, TRUNC(dindinv) AS report_date
  FROM invdetinv@heinens_custom_prod det, IDENTIFY_ITEMS_FILTERED it
  WHERE det.dincinl=it.dincinl
  AND det.dinsite=:param2
),
valid_calendar AS (
  SELECT DISTINCT TRUNC(eindinv) AS report_date
  FROM inventinv@heinens_custom_prod
  WHERE TRUNC(eindinv) >= TRUNC(SYSDATE-365)
  AND einsite=:param2
),
calendar_with_pos AS (
  SELECT
    report_date,
    ROW_NUMBER() OVER (ORDER BY report_date) AS calendar_pos
  FROM valid_calendar
),
item_valid_days AS (
  SELECT DISTINCT det.dincinl AS item_code, TRUNC(dindinv) AS report_date
  FROM invdetinv@heinens_custom_prod det
  JOIN IDENTIFY_ITEMS_FILTERED it ON det.dincinl = it.dincinl
  WHERE det.dinsite = :param2
),
joined_ranked AS (
  SELECT
    i.item_code,
    i.report_date,
    c.calendar_pos,
    ROW_NUMBER() OVER (PARTITION BY i.item_code ORDER BY c.calendar_pos) AS item_pos
  FROM item_valid_days i
  JOIN calendar_with_pos c ON i.report_date = c.report_date
),
grouped AS (
  SELECT
    item_code,
    report_date,
    calendar_pos - item_pos AS group_id
  FROM joined_ranked
),
Enriched_data AS(
SELECT einsite "Store #", 
       to_char(maxDinv,''RRRR'') || 
        FLOOR((maxDinv - TRUNC(TRUNC(maxDinv, ''YYYY'') - MOD(TO_NUMBER(TO_CHAR(TRUNC(maxDinv, ''YYYY''), ''D'')) - 1, 7))) / 7) + 1 
       weekNumber,
       to_char(maxDinv,''MM/DD/RRRR'') "Hole date",
       to_char(maxDinv,''DAY'') "Day of the week",
       (SELECT "Vendor" 
        FROM (select foucnuf || ''/'' || fccnum || ''/'' || aranfilf  || '' | '' || foulibl "Vendor", MAX(aradfin)
              from artuc@heinens_custom_prod, foudgene@heinens_custom_prod, artul@heinens_custom_prod, fouccom@heinens_custom_prod
              where aracfin=foucfin and aracinr=arucinr  AND arucinl=dincinl
              AND fccccin=araccin
              and aratfou=1 
              AND pkresrel.isSiteBelongToNode@heinens_custom_prod(1,:param2, arasite, ''1'')=1 
              GROUP BY foucnuf || ''/'' || fccnum || ''/'' || aranfilf  || '' | '' || foulibl ORDER BY 2 DESC) 
        where rownum=1) "Supplier code",
       (SELECT "Supplier type" 
        FROM (select decode(VENDOR_CODE, null, foutype,0) "Supplier type", MAX(aradfin)
              from artuc@heinens_custom_prod, foudgene@heinens_custom_prod, artul@heinens_custom_prod, fouccom@heinens_custom_prod, sbt_vendor
              where aracfin=foucfin and aracinr=arucinr  AND arucinl=dincinl
              AND fccccin=araccin
              and aratfou=1 
              and foucnuf=vendor_code(+)
              AND pkresrel.isSiteBelongToNode@heinens_custom_prod(1,:param2, arasite, ''1'')=1 
              GROUP BY VENDOR_CODE, foutype ORDER BY 2 DESC) 
        where rownum=1) "Supplier type",
       (SELECT siteVendorCcomNfilf 
        FROM (select :param2 || aracfin || araccin || aranfilf siteVendorCcomNfilf,  MAX(aradfin)
              from artuc@heinens_custom_prod, artul@heinens_custom_prod 
              WHERE aracinr=arucinr AND arucinl=dincinl
              and aratfou=1 
              AND pkresrel.isSiteBelongToNode@heinens_custom_prod(1,:param2, arasite, ''1'')=1 
              GROUP BY :param2 || aracfin || araccin || aranfilf ORDER BY 2 DESC) 
        where rownum=1) siteVendorCcomNfilf,
        dincinl,
        (SELECT artcexr FROM artul@heinens_custom_prod, artrac@heinens_custom_prod WHERE arucinl=dincinl AND arucinr=artcinr) "Item code",
        (SELECT pkstrucobj.get_desc@heinens_custom_prod(1,arucinr,''HN'') FROM artul@heinens_custom_prod WHERE arucinl=dincinl ) "Item desc",
        pkartcoca.Get_Arccode@heinens_custom_prod(1,dincinl) "UPC",
        0 "Qty reported",
        (SELECT consecutive_day_count
           FROM (SELECT item_code,
                        MIN(report_date) AS start_date,
                        MAX(report_date) AS end_date,
                        COUNT(*) AS consecutive_day_count
                   FROM grouped nb
                  WHERE item_code = it.dincinl
                  GROUP BY item_code, group_id
                  ORDER BY end_date DESC)
          WHERE ROWNUM = 1) AS "Nb days",
          
       (SELECT case when trunc(sysdate) > aradfin then ''Check if discontinued.''
                    when aratcde != 1  then ''Check if discontinued.''
               end
        FROM (SELECT aratcde,  MAX(aradfin) aradfin
              from artuc@heinens_custom_prod, artul@heinens_custom_prod 
              WHERE aracinr=arucinr AND arucinl=dincinl
              and aratfou=1 
              AND pkresrel.isSiteBelongToNode@heinens_custom_prod(1,:param2, arasite, ''1'')=1 
              GROUP BY aratcde ORDER BY 2 DESC) 
        where rownum=1) "Comment",
        (SELECT MAX(dcdcincde) dcdcincde 
          FROM cdedetcde@heinens_custom_prod
          WHERE dcdsite=:param2
          AND dcdcinr=dincinr
          AND dcdetat >=5 ) "LastPOcincde",
       (SELECT ''X'' FROM aveprix@heinens_custom_prod, avetar@heinens_custom_prod, avescope@heinens_custom_prod 
        WHERE avicinv=dincinl AND TRUNC(SYSDATE) BETWEEN aviddeb AND avidfin
        AND avintar=aventar
        AND avestat =2 /* temporary */
        AND avontar=avintar
        AND pkresrel.isSiteBelongToNode@heinens_custom_prod(1,:param2, avorescint, ''1'')=1 
        AND TRUNC(SYSDATE) BETWEEN avoddeb AND avodfin AND ROWNUM=1) "on Promo",
        DECODE ("CLE",1,
                 (SELECT tattlibl FROM artattri@heinens_custom_prod,  tra_attrival@heinens_custom_prod
                  WHERE dincinr=aatcinr AND aatccla=''PRMO'' 
                  AND TRUNC(SYSDATE) BETWEEN aatddeb AND aatdfin 
                  AND tattccla=aatccla AND tattcode=aatcatt AND langue=''HN'' AND ROWNUM=1),
                 (SELECT tattlibl FROM artattri@heinens_custom_prod,  tra_attrival@heinens_custom_prod
                  WHERE dincinr=aatcinr AND aatccla=''PRM2'' 
                  AND TRUNC(SYSDATE) BETWEEN aatddeb AND aatdfin 
                  AND tattccla=aatccla AND tattcode=aatcatt AND langue=''HN'' AND ROWNUM=1)) "Promo type", dincinr,
       (SELECT sobcext FROM strucobj@heinens_custom_prod, strucrel@heinens_custom_prod 
        WHERE dincinr=objcint
        AND TRUNC(SYSDATE) BETWEEN objddeb AND objdfin
        AND objpere=sobcint) "Merch"
 FROM IDENTIFY_ITEMS_FILTERED it)
 SELECT "Store #" , weekNumber "Hole week",
        "Hole date", "Day of the week",
        CASE 
          WHEN "Merch" LIKE ''103%'' THEN ''Grocery''
          WHEN "Merch" LIKE ''102010%'' THEN ''Dairy''
          WHEN "Merch" LIKE ''102011%'' THEN ''Frozen''
          WHEN "Merch" LIKE ''102014%'' THEN ''Ice-cream''
          WHEN "Merch" LIKE ''101%'' THEN ''Meat''
          WHEN "Merch" LIKE ''104008%'' THEN ''Fresh Produce''
          WHEN "Merch" LIKE ''104019%'' THEN ''Floral''
          WHEN "Merch" LIKE ''104021%'' THEN ''Salad bar''
          WHEN "Merch" LIKE ''104025%'' THEN ''Bulk Produce''
          WHEN "Merch" LIKE ''105%'' THEN ''Bakery''
          WHEN "Merch" LIKE ''106007%'' THEN ''Deli''
          WHEN "Merch" LIKE ''106015%'' THEN ''PPD''
          WHEN "Merch" LIKE ''106016%'' THEN ''Cafe''
          WHEN "Merch" LIKE ''106022%'' THEN ''Speciality Cheese''
          WHEN "Merch" LIKE ''106033%'' THEN ''Seafood''
          WHEN "Merch" LIKE ''199%'' THEN ''General''
          ELSE ''Other''
        END "Dept.",
        "Supplier code",
        /*(SELECT (liscdlu + liscdma + liscdme + liscdje + liscdve + liscdsa + liscddi) || '' times/week''
         FROM lienserv WHERE (lissite||liscfin ||lisccin ||lisnfilf)=siteVendorCcomNfilf
         AND lissite=:param2
         AND TRUNC(SYSDATE) BETWEEN lisddeb AND lisdfin) "Frequency",*/
         (SELECT (DECODE(liscdlu,0,''X'',''M'') || DECODE(liscdma,0,''X'',''T'') || 
                  DECODE(liscdme,0,''X'',''W'') || DECODE(liscdje,0,''X'',''T'') || 
                  DECODE(liscdve,0,''X'',''F'') || DECODE(liscdsa,0,''X'',''S'') ||
                  DECODE(liscddi,0,''X'',''S'')) 
         FROM lienserv@heinens_custom_prod WHERE (lissite||liscfin ||lisccin ||lisnfilf)=siteVendorCcomNfilf
         AND lissite=:param2
         AND TRUNC(SYSDATE) BETWEEN lisddeb AND lisdfin) "Frequency",
         (SELECT to_char(MAX(ecddcom),''MM/DD/RR'') FROM cdeentcde@heinens_custom_prod WHERE ecdsite=:param2
          AND ecdsite || ecdcfin || ecdccin || ecdnfilf =siteVendorCcomNfilf) "Last vendor order",
         (SELECT to_char(MAX(serdrec),''MM/DD/RR'') FROM stoentre@heinens_custom_prod WHERE sersite=:param2
          AND sersite || sercfin || serccin || serfilf =siteVendorCcomNfilf)  "Last receipt",
         (SELECT to_char(MAX(ecddenvoi),''MM/DD/RR'') 
          FROM cdedetcde@heinens_custom_prod,
               cdeentcde@heinens_custom_prod  
          WHERE ecdsite=:param2
          AND dcdcinr=dincinr
          and dcdsite || dcdcfin || dcdccin || dcdnfilf =siteVendorCcomNfilf
          AND ecdcincde=dcdcincde) "Last item pending order",
         (SELECT to_char(MAX(dcddliv),''MM/DD/RR'') 
          FROM cdedetcde@heinens_custom_prod
          WHERE dcdsite=:param2
          and dcdsite || dcdcfin || dcdccin || dcdnfilf =siteVendorCcomNfilf
          AND dcdcinr=dincinr) "Last expected delivery order",
         (SELECT to_char(MAX(sdrsdrc),''MM/DD/RR'') 
          FROM stodetre@heinens_custom_prod, stoentre@heinens_custom_prod 
          WHERE sersite=:param2
          AND sdrcinr=dincinr
          AND sersite || sercfin || serccin || serfilf =siteVendorCcomNfilf
          AND sercinrec=sdrcinrec) "Last item receipt order",
          (SELECT MIN(fpldram) FROM fouplan@heinens_custom_prod WHERE fplsite||fplcfin||fplccin||fplnfilf=siteVendorCcomNfilf
           AND (TRUNC(fpldram) > TRUNC(SYSDATE) 
           OR (TRUNC(fpldram)= TRUNC(SYSDATE) AND to_char(SYSDATE,''HH24MI'')>fplhram))) "Next order",
        /* Order status (1. CUT, 2. AWAITING DELIVERY, 3. NOT ORDERED) */
         CASE 
            /* BA Sweetie SBT mgt only */
            WHEN "Supplier type" = 0 AND "Supplier code" = ''00284'' THEN
              NVL(
                  (SELECT CASE 
                            WHEN TO_CHAR("Hole date", ''D'') IN (''5'',''6'',''7'') THEN ''SBT (CUT)''
                            ELSE ''SBT (AWAITING DELIVERY)''
                          END
                  FROM cdedetcde@heinens_custom_prod d, cdeentcde@heinens_custom_prod ent
                  WHERE dcdsite=:param2
                  AND dcdsite || dcdcfin || dcdccin || dcdnfilf = siteVendorCcomNfilf
                  and dcdcincde="LastPOcincde"
                  AND dincinr=dcdcinr
                  AND ecdcincde=dcdcincde
                  AND dcdetat BETWEEN 3 AND 6                          /* exclude status 7 = cleared */
                  AND ecdetat between 3 and 6 
                  AND TRUNC(ecddcre) >=                                /* PO created on or after the relevant Friday */
                      CASE WHEN TO_CHAR("Hole date", ''D'') IN (''6'',''7'')
                            THEN NEXT_DAY(TRUNC("Hole date") - 14, ''FRIDAY'')   /* Fri/Sat hole ¿ prev-prev Fri */
                            ELSE NEXT_DAY(TRUNC("Hole date") - 7,  ''FRIDAY'')   /* Sun¿Thu hole ¿ last Fri      */
                      END
                  AND TRUNC("Hole date") >= TRUNC(ecddcre)             /* not a future PO */
                  AND ROWNUM=1
                  ),
                  ''SBT (NOT ORDERED)''
                )
            WHEN "Supplier type" = 0 then ''SBT''
            ELSE NVL((SELECT decode("Supplier type", 1, ''(DSD) '', ''(WHS) '') || ''CUT'' 
                      FROM cdedetcde@heinens_custom_prod   
                            WHERE dcdsite=:param2
                            AND dincinr=dcdcinr
                            and dcdcincde="LastPOcincde"
                            AND dcdral > 0 
                            AND dcdetat >=6
                      UNION
                      SELECT decode("Supplier type", 1, ''(DSD) '', ''(WHS) '') || ''CUT'' 
                      FROM cdedetcde@heinens_custom_prod   
                      WHERE dcdsite=:param2
                      AND dincinr=dcdcinr 
                      and dcdcincde="LastPOcincde"
                      AND dcdral = 0 
                      AND dcdetat=7
                      AND dcdcomm1 is not null
                      UNION
                      SELECT decode("Supplier type", 1, ''(DSD) '', ''(WHS) '') || ''CUT'' 
                    FROM cdedetcde@heinens_custom_prod,  foudgene@HEINENS_CUSTOM_PROD,  stoentre@heinens_custom_prod
                    WHERE dcdcincde="LastPOcincde"
                    AND dcdcfin=foucfin
                    AND foutype =1 /* DSD */
                    AND dincinr=dcdcinr
                    AND dcdsite=:param2
                    AND dcdetat>=5
                    AND sersite=:param2
                    AND sercincde=999999999 /* DSD receipt without order */
                    AND TRUNC(serdrec)>= TRUNC(dcddliv-1) 
                    AND sersite || sercfin || serccin || serfilf =siteVendorCcomNfilf
                    AND NOT EXISTS (SELECT 1 FROM stodetre@heinens_custom_prod
                            WHERE sdrcinr=dincinr
                            AND sercinrec=sdrcinrec)  AND  ROWNUM=1
                      ), 
                              
                              NVL((SELECT decode("Supplier type", 1, ''(DSD) '', ''(WHS) '') || ''RECEIVED'' 
                                  FROM (SELECT MAX(sdrsdrc) receiptDate
                                          FROM stodetre@heinens_custom_prod, stoentre@heinens_custom_prod 
                                          WHERE sersite=:param2
                                          AND sdrcinr=dincinr
                                          AND sersite || sercfin || serccin || serfilf =siteVendorCcomNfilf
                                          AND sercinrec=sdrcinrec)
                                  WHERE receiptDate >=TRUNC(SYSDATE-:param3) AND ROWNUM=1
                                  UNION 
                                  SELECT decode("Supplier type", 1, ''(DSD) '', ''(WHS) '') || ''RECEIVED'' 
                                  FROM stodetre@heinens_custom_prod,  stoentre@heinens_custom_prod 
                                  WHERE sersite=:param2
                                  AND sdrcinr=dincinr
                                  AND sercincde="LastPOcincde"
                                  AND sersite || sercfin || serccin || serfilf =siteVendorCcomNfilf
                                  AND trunc(sdrsdrc) >= trunc(SYSDATE-:param3)
                                  AND sercinrec=sdrcinrec AND ROWNUM=1
                                  ),
                                  
                            NVL((SELECT decode("Supplier type", 1, ''(DSD) '', ''(WHS) '') || ''AWAITING DELIVERY'' 
                                FROM cdedetcde@heinens_custom_prod d, cdeentcde@heinens_custom_prod ent
                                WHERE dcdsite=:param2
                              AND dincinr=dcdcinr
                              AND dcdsite || dcdcfin || dcdccin || dcdnfilf =siteVendorCcomNfilf
                              AND dcdcincde="LastPOcincde"
                              AND ecdcincde=dcdcincde
                              AND dcdetat between 3 and 5
                              AND ecdetat between 3 and 5 
                              AND d.dcdral > 0 AND ROWNUM=1),
                              decode("Supplier type", 1, ''(DSD) '', ''(WHS) '') || ''NOT ORDERED'')))
                      END "Last delivery status",
         "Item code", "Item desc", "UPC",
         decode("on Promo",''X'',NVL("Promo type",''IN STORE'')) "on Promo",
         /* "Promo type", */
         "Qty reported",  "Nb days", "Comment"
 FROM enriched_DATA
 WHERE "Nb days" >= :param3
 ORDER BY  "Nb days" DESC
</QUERY3>

