<ROOT>
    <QUERY>
    WITH CALACTUALWEEK AS (
select TRUNC(sysdate, ''DAY'') + level - 1 dayWeek
from  dual
connect by 7 >= level
),
CALWEEKS AS (
select to_char(SYSDATE- 7*LEVEL,''RRRR'') || 
        FLOOR((SYSDATE- 7*LEVEL - TRUNC(TRUNC(SYSDATE- 7*LEVEL, ''YYYY'') - MOD(TO_NUMBER(TO_CHAR(TRUNC(SYSDATE- 7*LEVEL, ''YYYY''), ''D'')) - 1, 7))) / 7) + 1 
       weekNumber, TRUNC(SYSDATE- 7*LEVEL,''D'') "1ST_DAY", TRUNC(SYSDATE- 7*LEVEL,''D'') + 6  "LAST_DAY"
from  dual
connect by 12 >= level 
),
COUNTEDHOLE AS (
SELECT DISTINCT einsite "Store #",  TRUNC(eindinv) "Holes date", to_char(dayWeek,''DAY'') "Day of the week",
                                (SELECT foucnuf 
                                  FROM (select foucnuf, MAX(aradfin)
                                        from artuc@heinens_custom_prod, foudgene@heinens_custom_prod 
                                        where aracfin=foucfin and aracinr=dincinr 
                                        and aratfou=1 
                                        AND pkresrel.isSiteBelongToNode@heinens_custom_prod(1,:param2, arasite, ''1'')=1 
                                        GROUP BY foucnuf ORDER BY 2 DESC) 
                                  where rownum=1) "Supplier code",
       artcexr
FROM inventinv@heinens_custom_prod, invdetinv@heinens_custom_prod,
     invsaisie@heinens_custom_prod, artrac@heinens_custom_prod, CALACTUALWEEK
WHERE isacininv=dincininv
AND eincininv=dincininv
AND eintinv = 22 /* Not PICS/RGIS */
AND dincinl=isacinl
AND trunc(eindinv)=dayWeek
/* AND isaqter=0 */
AND artcinr=dincinr
and einsite=:param2),
LISTCOUNT AS (
  SELECT :param2 "Store #",  dayWeek "Holes date",  to_char(dayWeek,''DAY'') "Day of the week",
         SUM(DECODE("Supplier code",''H090061'',1,0)) "Grocery",
         SUM(DECODE("Supplier code",''H091070'',1,0)) "Dairy",
         SUM(DECODE("Supplier code",''H091071'',1,0)) "Freezer",
         SUM(DECODE("Supplier code",''00284'',1,0)) "B.A. Sweetie",
         SUM(DECODE("Supplier code",''AO1706872'',1,0)) "Carmela",
         SUM(DECODE("Supplier code",''06190'',1,0)) "Euro",
         SUM(DECODE("Supplier code",''17383'',1,0)) "East side J.",
         SUM(DECODE("Supplier code",''00869'',1,0)) "Hillandale",
         SUM(DECODE("Supplier code",''17244'',1,0)) "Imperial",
         SUM(DECODE("Supplier code",''06966'',1,0)) "Lipari",
         SUM(DECODE("Supplier code",''07188'',1,0)) "Midland",
         SUM(DECODE("Supplier code",''07626'',1,0)) "Pierres",
         SUM(DECODE("Supplier code",''08313'',1,0)) "Sysco",
         SUM(DECODE("Supplier code",''08531'',1,0)) "UNFI",
         SUM(DECODE("Supplier code",''02076'',1,0)) "Wakefern",
         SUM(CASE WHEN "Supplier code" NOT IN (''H090061'',''H091070'',''H091071'',''17383'',''17244'',''06966'',
                                               ''00869'',''07188'', ''07626'',''08531'',''02076'', 
                                               ''08313'', ''06190'',''00284'',''AO1706872'') THEN 1
                  ELSE 0
             END)  "Others",
         COUNT(artcexr) "Counted"
  FROM CALACTUALWEEK,COUNTEDHOLE t
  WHERE dayWeek="Holes date"(+)
  GROUP BY :param2,  dayWeek ,  to_char(dayWeek,''DAY'') 
  ORDER BY "Holes date" ASC
),
/** HISTORY **/
HISTORY AS (
        SELECT DISTINCT einsite "Store #",  NULL "Holes date", 
         to_char(eindinv,''RRRR'') || 
        FLOOR((eindinv - TRUNC(TRUNC(eindinv, ''YYYY'') - MOD(TO_NUMBER(TO_CHAR(TRUNC(eindinv, ''YYYY''), ''D'')) - 1, 7))) / 7) + 1
         "Day of the week",
                to_char(eindinv,''D'') "Holes day",
                (SELECT foucnuf 
                  FROM (select foucnuf, MAX(aradfin)
                        from artuc@heinens_custom_prod, foudgene@heinens_custom_prod 
                        where aracfin=foucfin and aracinr=dincinr 
                        and aratfou=1 
                        AND pkresrel.isSiteBelongToNode@heinens_custom_prod(1,:param2, arasite, ''1'')=1 
                        GROUP BY foucnuf ORDER BY 2 DESC) 
                  where rownum=1) "Supplier code",
       artcexr
FROM inventinv@heinens_custom_prod, invdetinv@heinens_custom_prod,
     invsaisie@heinens_custom_prod, artrac@heinens_custom_prod, CALWEEKS
WHERE isacininv=dincininv
AND eincininv=dincininv
AND eintinv = 22 /* Not PICS/RGIS */
AND dincinl=isacinl
AND TRUNC(eindinv) BETWEEN "1ST_DAY" AND "LAST_DAY"
/* AND isaqter=0 */
AND artcinr=dincinr
and einsite=:param2),
HISTORYCOUNT AS (
  SELECT :param2 "Store #",   to_char(weekNumber) "Holes date",  
         ''WK '' || to_char("1ST_DAY", ''MM/DD'') || ''-'' || to_char("LAST_DAY", ''MM/DD'')  "Day of the week", 
         SUM(DECODE("Supplier code",''H090061'',1,0)) "Grocery",
         SUM(DECODE("Supplier code",''H091070'',1,0)) "Dairy",
         SUM(DECODE("Supplier code",''H091071'',1,0)) "Freezer",
         SUM(DECODE("Supplier code",''00284'',1,0)) "B.A. Sweetie",
         SUM(DECODE("Supplier code",''AO1706872'',1,0)) "Carmela",
         SUM(DECODE("Supplier code",''06190'',1,0)) "Euro",
         SUM(DECODE("Supplier code",''17383'',1,0)) "East side J.",
         SUM(DECODE("Supplier code",''00869'',1,0)) "Hillandale",
         SUM(DECODE("Supplier code",''17244'',1,0)) "Imperial",
         SUM(DECODE("Supplier code",''06966'',1,0)) "Lipari",
         SUM(DECODE("Supplier code",''07188'',1,0)) "Midland",
         SUM(DECODE("Supplier code",''07626'',1,0)) "Pierres",
         SUM(DECODE("Supplier code",''08313'',1,0)) "Sysco",
         SUM(DECODE("Supplier code",''08531'',1,0)) "UNFI",
         SUM(DECODE("Supplier code",''02076'',1,0)) "Wakefern",
         SUM(CASE WHEN "Supplier code" NOT IN (''H090061'',''H091070'',''H091071'',''17383'',''17244'',''06966'',
                                               ''00869'',''07188'', ''07626'',''08531'',''02076'', 
                                               ''08313'',''06190'',''00284'',''AO1706872'') THEN 1
                  ELSE 0
             END)  "Others",
         COUNT(artcexr) "Counted",
         COUNT(DISTINCT("Holes day")) "Nb days counted" 
  FROM HISTORY t, CALWEEKS
  WHERE weekNumber= "Day of the week"(+)
  GROUP BY :param2, weekNumber, ''WK '' || to_char("1ST_DAY", ''MM/DD'') || ''-'' || to_char("LAST_DAY", ''MM/DD'')
)
SELECT "Store #",  to_char("Holes date", ''MM/DD/RR'') "Holes date",   "Day of the week",
       "Grocery","Dairy","Freezer", "Euro", "B.A. Sweetie", "Carmela", "East side J.", "Hillandale",  "Imperial",
       "Lipari", "Midland", "Pierres", "Sysco", "UNFI", "Wakefern",  
       "Others", "Counted", CASE WHEN "Counted" > 0 THEN 1 ELSE 0 END "Nb days counted"  
  FROM (SELECT * FROM LISTCOUNT ORDER BY  "Holes date" ASC)
UNION ALL
SELECT * 
  FROM (SELECT * FROM HISTORYCOUNT ORDER BY "Holes date" DESC)

</QUERY>
