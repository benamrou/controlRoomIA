<QUERY2>
WITH CALWEEKS AS (
select to_char(SYSDATE- 7*(LEVEL-1),''RRRR'') || 
        FLOOR((SYSDATE- 7*(LEVEL-1) - TRUNC(TRUNC(SYSDATE- 7*(LEVEL-1), ''YYYY'') - MOD(TO_NUMBER(TO_CHAR(TRUNC(SYSDATE- 7*(LEVEL-1), ''YYYY''), ''D'')) - 1, 7))) / 7) + 1 
       weekNumber, TRUNC(SYSDATE- 7*(LEVEL-1),''D'') "1ST_DAY", TRUNC(SYSDATE- 7*(LEVEL-1),''D'') + 6  "LAST_DAY"
from  dual
connect by 13 >= level 
)
  SELECT DISTINCT einsite "Store #",  weekNumber "Holes week",
                 to_char(eindinv,''MM/DD/RR'') "Holes date", to_char(eindinv,''DAY'') "Day of the week",
                (SELECT foucnuf || '' | '' || foulibl
                  FROM (select foucnuf, foulibl, MAX(aradfin)
                        from artuc@heinens_custom_prod, foudgene@heinens_custom_prod 
                        where aracfin=foucfin and aracinr=dincinr 
                        and aratfou=1 
                        AND pkresrel.isSiteBelongToNode@heinens_custom_prod(1,:param2, arasite, ''1'')=1 
                        GROUP BY foucnuf, foulibl ORDER BY 3 DESC) 
                  where rownum=1) "Supplier code",
       artcexr "Item code",
       pkstrucobj.get_desc@heinens_custom_prod(1, artcinr,''HN'') "Item desc.",
       pkartcoca.Get_Arccode@heinens_custom_prod(1,dincinl) "UPC",
       0 "Qty reported"
  FROM inventinv@heinens_custom_prod, invdetinv@heinens_custom_prod,
     invsaisie@heinens_custom_prod, artrac@heinens_custom_prod, CALWEEKS
  WHERE isacininv=dincininv
  AND eincininv=dincininv
  AND eintinv = 22 /* Not PICS/RGIS */
  AND dincinl=isacinl
  AND trunc(eindinv) between "1ST_DAY" and "LAST_DAY"
/* AND isaqter=0 */
  AND artcinr=dincinr
  AND einsite=:param2
order by to_char(eindinv,''MM/DD/RR'') desc
