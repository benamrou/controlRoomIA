-- UPDATE item type for same merchandise code (806) type                --
--     Same type are DSD, Warehouse, Ingredient can be switched - Only COMMON MERHANDISE
-- Query to get the same type
-- SELECT DISTINCT(arttypp), pkparpostes.get_postlibl(0,1030,arttypp,'HN'), pkparpostes.get_postvan1(0,1030,arttypp),
--       pkparpostes.get_postlibl(0,1060, pkparpostes.get_postvan1(0,1030,arttypp),'HN')
-- FROM artrac;
-- --------------------------------------------------------------------  --
-- Type| Desc.                | GOLD internal type
-- --------------------------------------------------------------------  --
--  0  | Packing              | 0- Packing
--  12 | DSD                  | 1- Common merchandise
--  3  | Generic              | 3- Generic
--  9  | KIT / Heterogen. LU  | 9-KIT / Heterogen. LU
--  11 | Supply / Ingredient  | 1-Common merchandise
--  10 | Warehouse            | 1-Common merchandise
-- --------------------------------------------------------------------  --
-- on_error = -1 : error procesing                                       --
--         0 : everything ok                                             --
--                                                                       --
---------------------------------------------------------------------------
FUNCTION change_item_type(num_log IN NUMBER,
          in_classe IN NUMBER,
          in_item_code IN VARCHAR2,
          in_from_type IN NUMBER,
          in_to_type IN NUMBER) RETURN NUMBER
IS
 PRAGMA AUTONOMOUS_TRANSACTION;
  on_error       NUMBER;
  pt_1030        NUMBER;
  parvan1_1030_X NUMBER;
  Progname ERREURPRG.ERRPROG%TYPE;

BEGIN
  on_error := 0;
  pt_1030 := 1030;
  Progname := 'changeType';

  --recuperation parvan1_2310_3
  parvan1_1030_X := pkparpostes.get_postvan1(num_log, in_classe,pt_1030,in_to_type);


  --verification parametres
  IF(in_to_type is NULL OR
     parvan1_1030_X IS NULL OR
     parvan1_1030_X != 1) THEN
    on_error := -1;
    PKERREURS.fc_erreur(num_log, Progname, 'Can''t process item ' || in_item_code || ' trying to switch from ' || in_from_type || ' to ' || in_to_type );
    RETURN on_error;
  END IF;


  BEGIN
    UPDATE ARTRAC SET ARTTYPP=in_to_type
    WHERE ARTCEXR=in_item_code;

    EXCEPTION WHEN no_data_found THEN
    PKERREURS.fc_erreur(num_log, Progname, 'Item ' || in_item_code || ' not found.' );
    RETURN on_error;
  END;

  PKERREURS.fc_erreur(num_log, Progname, 'Item ' || in_item_code || ' switched from  ' || in_from_type || ' to ' || in_to_type );
  COMMIT;
  RETURN on_error;

END change_item_type;

FUNCTION fix_invoice(num_log IN NUMBER, invoice_number IN VARCHAR2) RETURN NUMBER
IS
 PRAGMA AUTONOMOUS_TRANSACTION;
  on_error       NUMBER;
  v_rowcount     NUMBER;
  v_id           NUMBER;
  Progname ERREURPRG.ERRPROG%TYPE;

BEGIN
  on_error := 0;
  v_id := 0;
   INSERT INTO ERREURPRG (errprog, errstat, errtrid, errord, errmess, errdcre, errutil)
                VALUES ('FIX_INVOICE', 0, 1, 1 , 'Start session ', SYSDATE, 'PCK'); 
      COMMIT;
 -- Fix invalid document amount (net cost is not correct)
 UPDATE CFDDTDOC 
 SET DDADPUN = DDADPUB,
     DDADPNN = DDADPUB,
     DDAUTIL='FIX_INVOICE',
     DDADMAJ=SYSDATE
  WHERE (ddarfou=invoice_number OR invoice_number = '-1')
  AND abs(ddadpub - ddadpun) >= 0.001 AND abs(ddadpub - ddadpnn) >= 0.001 
  AND NOT EXISTS (SELECT 1 FROM storemre, cfdendoc, stodetre
                 WHERE edccfin=ddacfin AND edcrfou=ddarfou AND edcndoc=sdrcinrec 
                 AND srrcinrec=sdrcinrec AND srrnlrec=sdrnlrec AND sdrcinls=ddacinl)
 AND trunc(ddadmaj) = trunc(SYSDATE);

 COMMIT;
 -- Variance detected and updated by user.
UPDATE CFDDTDOC 
 SET DDAVPNN = ddafpnn,
     ddavqte=ddafqte,
     DDAUTIL='FIX_INVOICE',
     DDADMAJ=SYSDATE
 WHERE abs(ddavpnn * ddavqte  - ddafpnn * ddafqte) >= 0.001
 AND (ddarfou=invoice_number OR invoice_number = '-1')
 AND ddafqte != 0
 AND EXISTS (SELECT 1 FROM cfdecart WHERE ectrfou=ddarfou 
                AND ectcinl=ddacinl AND ectsite=ddasite AND ectcfin=ddacfin AND ecttype IN ('A','B'))
 AND trunc(ddadmaj) = trunc(SYSDATE);

  COMMIT;
 v_rowcount := SQL%ROWCOUNT;
 INSERT INTO ERREURPRG (errprog, errstat, errtrid, errord, errmess, errdcre, errutil)
        VALUES ('FIX_INVOICE', 0, 1, 1 , to_char(v_rowcount)   || ' rows with invalid validated amount variance A and B' , SYSDATE, 'PCK'); 
          COMMIT;

UPDATE CFDDTDOC 
 SET DDAVPNN = ddadpnn,
     ddavqte = ddadqte,
     DDAUTIL='FIX_INVOICE',
     DDADMAJ=SYSDATE
 WHERE abs(ddavpnn * ddavqte  - ddadpnn * ddadqte) >= 0.001
 AND (ddarfou=invoice_number OR invoice_number = '-1')
 AND ddadqte != 0 
 AND EXISTS (SELECT 1 FROM cfdecart WHERE ectrfou=ddarfou 
                AND ectcinl=ddacinl AND ectsite=ddasite AND ectcfin=ddacfin AND ecttype IN ('C','D'))
 AND trunc(ddadmaj) = trunc(SYSDATE);

  COMMIT;
 v_rowcount := SQL%ROWCOUNT;
 INSERT INTO ERREURPRG (errprog, errstat, errtrid, errord, errmess, errdcre, errutil)
        VALUES ('FIX_INVOICE', 0, 1, 1 , to_char(v_rowcount)   || ' rows with invalid validated amount variance C and D' , SYSDATE, 'PCK'); 
          COMMIT;
 -- No Variance use invoice information
 UPDATE CFDDTDOC 
 SET DDAVPNN = DDAFPNN,
     ddavqte = ddafqte,
     DDAUTIL='FIX_INVOICE',
     DDADMAJ=SYSDATE
 WHERE abs(ddavpnn*ddavqte - ddafpnn*ddafqte) >= 0.001 
 AND (ddarfou=invoice_number OR invoice_number = '-1')
 AND ddafqte != 0
 AND NOT EXISTS (SELECT 1 FROM cfdecart WHERE ectrfou=ddarfou 
                AND ectcinl=ddacinl AND ectsite=ddasite AND ectcfin=ddacfin)
 AND trunc(ddadmaj) = trunc(SYSDATE);
            COMMIT;
 v_rowcount := SQL%ROWCOUNT;
 INSERT INTO ERREURPRG (errprog, errstat, errtrid, errord, errmess, errdcre, errutil)
        VALUES ('FIX_INVOICE', 0, 1, 1 , to_char(v_rowcount)   || ' rows with invalid validated amount no variance but vendor amount valid' , SYSDATE, 'PCK'); 


-- 12/03/19 Fix Sherwood issue (adding remaing to reconcile invalid amount
 UPDATE CFDDTDOC 
 SET DDAVQTE = DDADQTE,
     DDAUTIL='FIX_INVOICE',
     DDADMAJ=SYSDATE
 WHERE EXISTS (select 1 
               FROM cfddtfac, artrac WHERE dfarfou=ddarfou AND dfacfin=ddacfin 
               AND dfacinl=ddacinl AND dfatdoc=14
               AND dfacinr=artcinr AND arttypp=3)
 AND (ddarfou=invoice_number OR invoice_number = '-1')
 AND EXISTS (SELECT 1 FROM cfdecart WHERE ectrfou=ddarfou 
               AND ectcinl=ddacinl AND ectsite=ddasite AND ectcfin=ddacfin AND ecttdoc=14)
 AND trunc(ddadmaj) = trunc(SYSDATE);

 COMMIT;
 v_rowcount := SQL%ROWCOUNT;
 INSERT INTO ERREURPRG (errprog, errstat, errtrid, errord, errmess, errdcre, errutil)
        VALUES ('FIX_INVOICE', 0, 1, 1 , to_char(v_rowcount)   || ' rows with invalid remaing amount no variance but document qty valid' , SYSDATE, 'PCK'); 



  COMMIT;


   INSERT INTO ERREURPRG (errprog, errstat, errtrid, errord, errmess, errdcre, errutil)
                VALUES ('FIX_INVOICE', 0, 1, 1 , 'End session ', SYSDATE, 'PCK'); 
                  COMMIT;

  -- If invoice qty is not set pay what we receive
  UPDATE cfddtdoc
  SET ddavpnn=ddafpnn,
      ddavqte=ddafqte
  WHERE  ddafqte=0 
  AND trunc(ddadmaj) = trunc(SYSDATE)
  AND NOT EXISTS (SELECT 1 FROM cfdecart WHERE ectrfou=ddarfou 
                AND ectcinl=ddacinl AND ectsite=ddasite AND ectcfin=ddacfin);

  COMMIT;

  RETURN on_error;

END fix_invoice;

-- Create additional placeholder line item for the manufacturing plant
-- Having the item in order helped the receiver in the warehouse to receive the product even if the item
-- was not in the Production order
/*
PROCEDURE mfgPlaceOrder(num_log IN NUMBER, v_whs IN varchar2, v_mfgVendor in varchar2,
                       v_intetat in varchar2, v_intrefext in varchar2, v_intnlig in varchar2,
                       v_intfich in varchar2, v_intutil in varchar2, o_return OUT NUMBER) IS*/


PROCEDURE mfgPlaceOrder(o_return OUT VARCHAR) IS
   v_whs int;
   v_intid INTCDE.INTID%TYPE;
   v_mfgVendor varchar2(10);
   v_intetat int;
   v_intrefext varchar2(20);
   v_intnlig int;
   v_intfich  varchar2(100);
   v_intutil varchar2(30);
   v_intori int;
   v_rowcount int;
BEGIN
  o_return := '0';
  v_rowcount :=0;
  v_whs := 93080;
  v_mfgVendor := 'XMF001';
  v_intetat := 5; /* Status of the order */
  v_intrefext := '';
  v_intnlig := 1000;
  v_intfich := 'JF_ORDERS';
  v_intutil := 'JF_ORDERS';
  v_intori := 906; /* External */
  BEGIN

   INSERT INTO ERREURPRG (errprog, errstat, errtrid, errord, errmess, errdcre, errutil)
                VALUES ('mfgPlaceOrder', 0, 1, 1 , 'Start session ' ||   v_whs || '/' || v_mfgVendor, SYSDATE, 'SPE'); 
     COMMIT;
     /* Adjust uauvc *//*
     UPDATE INTCDE SET INTUAUVC=(SELECT PKARTSTOCK.GET_SKUUNITS( 1, arucinl)
                                 FROM artul , artvl
                                 where arlcexr=intcode
                                 and arlcexvl=intcexvl
                                 and arlseqvl=aruseqvl
                                 and arutypul=inttypul),
                        INTQTEC = (SELECT PKARTSTOCK.GET_SKUUNITS( 1, arucinl)
                                 FROM artul , artvl
                                 where arlcexr=intcode
                                 and arlcexvl=intcexvl
                                 and arlseqvl=aruseqvl
                                 and arutypul=inttypul)*INTQTEC
     WHERE trunc(intdtrt)=trunc(sysdate)
                  and intstat=0
                  and intcnuf=v_mfgVendor;*/
     BEGIN 
       SELECT intid 
       INTO v_intid
       FROM INTCDE
       WHERE INTCNUF=v_mfgVendor
       AND trunc(intdcom)=trunc(SYSDATE)
       AND INTSTAT=0
       AND rownum=1;
     EXCEPTION
      WHEN OTHERS THEN
        pkgenerencom.generencomext( 1,0, v_whs, v_intid);
      END;  

     INSERT INTO INTCDE 
              (INTID, /*External order number*/
               INTLCDE, /* External order line number */
               INTSITE, /* Site code */
               INTCNUF, /* Supplier external code */
               INTCCOM, /* Commercial contract code */
               INTNFILF, /* Supplier address chain code */
               INTFILC,  /* Customer address chain code */
               INTCONF,  /* To be confirmed (1:yes, 0:no) */
               INTGREL,  /* Back orders managed (1:yes, 0:no) */
               INTCOUC,  /* Cover (1:yes, 0:no) */
               INTENLEV, /* Pick-up  allowed(1:yes, 0:no) */
               INTDCOM, /* Order date */
               INTDLIV, /* Order date */
               INTCODE, /* Article external code*/
               INTRCOM, /* Code of reference to order */
               INTCEXVA, /* Purchase variant external code*/
               INTCEXVL, /* LV external code */
               INTQTEC, /* Ordered quantity in SKU */
               INTUAUVC, /* Coefficient for UA conversion in SKU */
               INTSTAT, /* Interface line status *Table 512 */
               INTLDIST, /* Presence of a distribution list (1:yes, 0:no) */
               INTETAT, /* Order status *Table 502 */
               INTURG, /* Urgency indicator *Table 1406 */
               INTFRAN, /* Carriage free (1:yes, 0:no) */
               INTNLIG, /* Line number */
               INTFICH, /* Loaded file name */
               INTNERR, /* Error message no */
               INTMESS, /* Error message */
               INTDCRE, /* Creation date */
               INTDMAJ, /* Date of last update */
               INTUTIL, /* Last user */
               INTDTRT, /* Processing date */
               INTALTF, /* Supplier spoiling (1:yes, 0:no) */
               INTTYPUL, /* Code identifying the LU type *Table 731 */
               INTIRECYC, /* Recycling activation indicator */
               INTFLIR, /* Reception Interception Indicator */
               INTREFEXT, /* External Order reference */
               INTCOML1, /* Production order number */
               INTORI)
          SELECT v_intid, v_intnlig +rownum+1, v_whs,
              v_mfgVendor, fccnum, aranfilf, 1 /* v_intfilc*/,  0 /*@v_intconf*/,
              0 /*@v_intgrel*/, 0 /*@v_intcouc*/, 0 /*@v_intenlev*/, trunc(sysdate) /*@v_intdcom*/, trunc(sysdate) /*@v_intdliv*/, 
              aracexr, nvl(ararefc,'-1'), aracexta, aracexvl,
              1*PKARTSTOCK.GET_SKUUNITS( 1, arucinl) /* qty */,  PKARTSTOCK.GET_SKUUNITS( 1, arucinl) /*@v_intuauvc*/, 0 /*@v_intstat*/, 0 /*@v_intldist */,
              v_intetat, 1 /*v_inturg*/, 0 /*@v_intfran*/, v_intnlig +rownum+1,
              v_intfich, null /*@v_intnerr*/, null /*@v_intmess*/, 
              sysdate /*@v_intdcre*/, sysdate /*@v_intdmaj*/, v_intutil, trunc(sysdate) /*@v_intdtrt*/,
              0 /*@v_intaltf*/, arutypul /*@v_inttypul*/, 0 /*@v_intirecyc*/, 0 /*@v_intflir*/,
              nvl(v_intrefext,''), 'placeholder' /*@v_intcoml1*/,
              v_intori
          FROM ARTUC , FOUDGENE ,  FOUCCOM, artul
          WHERE aracfin=foucfin
          and foucnuf=v_mfgVendor
          and araccin=fccccin
          and aracinl=arucinl
          and arasite=v_whs
          and trunc(sysdate) between araddeb and aradfin 
          and aratcde=1
          /* 10/18/24: Exclude 199722 */
          /* 02/17/2025 : Eric put back 199722 */
          --and aracexr not in ('199722')
          and not exists (select 1 from INTCDE where trunc(intdtrt)=trunc(sysdate)
                  and intstat=0
                  and intcode=aracexr
                  and intcnuf=v_mfgVendor)
          /* 01/10/2025: Only on-stock items */
           AND EXISTS (SELECT 1 from ARTASENT WHERE trunc(sysdate) between  aloddeb and alodfin
                      and aloseqvl=araseqvl
                      AND alocomm = 0 /* On-stock */
                      and alosite =v_whs
             );

     v_rowcount :=  SQL%ROWCOUNT;
      INSERT INTO ERREURPRG (errprog, errstat, errtrid, errord, errmess, errdcre, errutil)
          VALUES ('mfgPlaceOrder', 0, 1, 1 , 'Loaded nb placeholder: ' || v_rowcount, SYSDATE, 'SPE'); 

     /* Remove allotment item */     
     DELETE INTCDE --set intmess='ALLOTMENT'
     WHERE trunc(intdcom)=trunc(sysdate) 
     and intutil=v_intutil 
     and intstat=0 
     and not exists (select 1 from artasent, artvl
                     where aloseqvl=arlseqvl
                     and trunc(sysdate) between aloddeb and alodfin
                     and alocomm =0 /* No on-stock */
                     and alosite=93080
                     and arlcexr=intcode);

     COMMIT;
    EXCEPTION
      WHEN OTHERS THEN
        dbms_output.put_line('Error... ' || SQLCODE || SQLERRM );
        ROLLBACK;
        o_return := '-1';
    END;

   INSERT INTO ERREURPRG (errprog, errstat, errtrid, errord, errmess, errdcre, errutil)
                VALUES ('mfgPlaceOrder', 0, 1, 1 , 'End session ', SYSDATE, 'SPE'); 
     COMMIT;

END mfgPlaceOrder;

